{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "scoreref",
	"main": "dist/scoreref/index.js",
	"no_bundle": true,
	"compatibility_date": "2026-06-21",
	"compatibility_flags": ["nodejs_compat"],
	"placement": { "mode": "smart" },
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": true,
			"persist": true,
			"head_sampling_rate": 1
		}
	},
	"upload_source_maps": true,
	"durable_objects": {
		"bindings": [
			{
				"name": "SCOREREF_DO",
				"class_name": "ScorerefDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_classes": ["ScorerefDO"]
		}
	],
	"triggers": {
		"crons": ["* * * * *"]
	},
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*", "/do/*"]
	},
	"vpc_services": [
		{
			"binding": "VPC_SERVICE",
			"service_id": "019ee405-bfe8-7903-bebd-83312960a38f",
			"remote": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "SCOREREF_KV",
			"id": "c0ded4a89de741588b15352b39cf3592"
		}
	]
}
