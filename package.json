{
	"name": "scoreref",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vue-tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "vue-tsc && vite build && wrangler deploy --dry-run",
		"deploy": "wrangler deploy --config wrangler.prod.json",
		"dev": "vite",
		"dev:remote": "wrangler dev --remote --config wrangler.prod.json",
		"lint": "eslint .",
		"preview": "npm run build && vite preview"
	},
	"dependencies": {
		"element-plus": "^2.9.0",
		"hono": "4.11.1",
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@eslint/js": "9.39.1",
		"@types/node": "24.10.1",
		"@vitejs/plugin-vue": "^5.2.0",
		"eslint": "9.39.2",
		"globals": "16.5.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"vue-tsc": "^2.2.0",
		"wrangler": "4.56.0"
	}
}
