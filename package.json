{
	"name": "scoreref",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "vue-tsc && vite build && wrangler deploy --dry-run",
		"deploy": "wrangler deploy --config wrangler.prod.json",
		"dev": "vite",
		"dev:remote": "wrangler dev --remote --config wrangler.prod.json",
		"lint": "eslint .",
		"preview": "npm run build && vite preview"
	},
	"dependencies": {
		"hono": "4.11.1",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router-dom": "^7.6.0"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "1.15.3",
		"@cloudflare/workers-types": "^4.20260625.1",
		"@eslint/js": "9.39.1",
		"@tailwindcss/vite": "^4.1.4",
		"@types/node": "24.10.1",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@vitejs/plugin-react": "^4.6.0",
		"eslint": "9.39.2",
		"globals": "16.5.0",
		"lucide-react": "^0.510.0",
		"tailwindcss": "^4.1.4",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"wrangler": "4.51.0"
	}
}
