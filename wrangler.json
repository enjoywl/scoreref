{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "scoreref",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"vpc_services": [
		{
			"binding": "VPC_SERVICE",
